# ==============================================================================
# Nonwoven AI Agent — Environment Configuration (TypeScript)
# ==============================================================================

# -- Simulation Mode -----------------------------------------------------------
# Set to 'true' to generate synthetic Modbus data for local testing.
# Set to 'false' in production to connect to the physical HMI.
SIMULATION_MODE=true

# -- Ollama / LLM --------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0

# -- HMI / Modbus --------------------------------------------------------------
HMI_IP=192.168.1.17
HMI_PORT=502

# -- Email Recipients (comma-separated) ----------------------------------------
ALERT_RECIPIENTS=manager@yourfactory.com
REPORT_RECIPIENTS=manager@yourfactory.com,director@yourfactory.com

# -- SMTP Service (Nodemailer) -------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SENDER_EMAIL=your_email@gmail.com
SENDER_NAME="Nonwoven AI Agent"

# -- Database ------------------------------------------------------------------
DB_PATH=nonwoven_data.db

# -- Timing (Seconds and cron) -------------------------------------------------
MODBUS_POLL_INTERVAL=2
DB_SAMPLE_INTERVAL=30
ANOMALY_CHECK_INTERVAL=30
ALERT_COOLDOWN_SECONDS=300

# -- Flask / Express Server ----------------------------------------------------
EXPRESS_PORT=5000
