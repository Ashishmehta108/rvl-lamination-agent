# Backend
BACKEND_PORT=7000
API_AUTH_TOKEN=dev-local-token
MCP_AUTH_TOKEN=dev-local-token

# Postgres (Drizzle + pg-boss)
POSTGRES_URL=postgresql://rvl:rvl@127.0.0.1:5432/rvl?schema=public

# MongoDB (Prisma)
MONGODB_URL=mongodb://rvl:rvl@127.0.0.1:27017/rvl?authSource=admin

# Ollama local LLM
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=phi4-mini
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0
OLLAMA_KEEP_ALIVE=30s
LLM_TIMEOUT_MS=25000

# RAG
RAG_DB_DIR=./data/rag
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=6
ARTIFACTS_DIR=./data/artifacts

# Next.js (Electron loads this)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:7000
NEXT_PUBLIC_API_AUTH_TOKEN=dev-local-token

# ML Pipeline (packages/ml/server.py)
ML_SERVER_URL=http://127.0.0.1:7100
ML_SERVER_PORT=7100
ML_DATA_DIR=./data/ml
ML_BASELINE_DAYS=7
ML_CONTAMINATION=0.05
ML_ANOMALY_THRESHOLD=-0.5
ML_N_ESTIMATORS=200
ML_RETRAIN_CRON=0 2 * * 0
MACHINE_ID=lamination-01
MACHINE_REVISION=v1

