# # Backend
# BACKEND_PORT=7000
# API_AUTH_TOKEN=dev-local-token
# MCP_AUTH_TOKEN=dev-local-token
# JWT_SECRET=change-me-in-production-min-32-chars

# # Postgres (Drizzle + pg-boss)
# POSTGRES_URL=postgresql://rvl:rvl@127.0.0.1:5432/rvl?schema=public

# # MongoDB (Prisma)
# MONGODB_URL=mongodb://rvl:rvl@127.0.0.1:27017/rvl?authSource=admin

# # Ollama local LLM (chat)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:1b
# OLLAMA_NUM_CTX=4096
# OLLAMA_TEMPERATURE=0
# OLLAMA_TOP_P=0.9
# OLLAMA_REPEAT_PENALTY=1.15
# OLLAMA_KEEP_ALIVE=30s
# LLM_TIMEOUT_MS=40000
# # Heuristic plan: model = one small JSON classify call before chat; regex = skip that call
# QUERY_CLASSIFIER_MODE=model
# QUERY_CLASSIFIER_TIMEOUT_MS=5000
# QUERY_DECOMPOSER_TIMEOUT_MS=8000
# # Diagnostic sub-query decomposition always calls Bedrock (even if AI_PROVIDER=gemini); requires AWS credentials.

# # Ollama report narrative (defaults to OLLAMA_MODEL if unset). Example: lfm2.5-thinking
# OLLAMA_REPORT_MODEL=lfm2.5-thinking:1.2b
# OLLAMA_REPORT_NUM_CTX=8192
# OLLAMA_REPORT_TEMPERATURE=0

# # RAG
# RAG_DB_DIR=./data/rag
# OLLAMA_EMBED_MODEL=nomic-embed-text
# RAG_TOP_K=4
# ARTIFACTS_DIR=./data/artifacts

# # Next.js (Electron loads this)
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:7000
# NEXT_PUBLIC_API_AUTH_TOKEN=dev-local-token
# # Shown in chat UI subtitle (match your Ollama pull, e.g. llama3.2:3b)
# NEXT_PUBLIC_OLLAMA_MODEL_LABEL=llama3.2:1b

# # SMTP (alert emails + scheduled report emails; optional in dev)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SENDER_NAME=RVL Lamination Agent
# SENDER_EMAIL=

# # Report email (comma-separated). Leave empty to skip sending completed reports.
# REPORT_EMAIL_TO=

# # Chat API rate limit (per IP + Authorization prefix, per minute)
# CHAT_RATE_LIMIT_MAX=30

# # ML Pipeline (packages/ml/server.py)
# ML_SERVER_URL=http://127.0.0.1:7100
# ML_SERVER_PORT=7100
# ML_DATA_DIR=./data/ml
# ML_BASELINE_DAYS=7
# ML_CONTAMINATION=0.05
# ML_ANOMALY_THRESHOLD=-0.5
# ML_N_ESTIMATORS=200
# ML_RETRAIN_CRON=0 2 * * 0
# MACHINE_ID=lamination-01
# MACHINE_REVISION=v1

# # Simulator (apps/backend simulate script): burst WINDER_TENSION_PCT above alarm for report/alert testing.
# # With SIM_INJECT_ALERTS=1, open alerts appear on the web Dashboard; run a report to see them in HTML/email.
# SIM_INJECT_ALERTS=1
# # SIM_INJECT_ALERTS_EVERY=12

# # Production: set NODE_ENV=production and replace dev-local-token values for API_AUTH_TOKEN
# # and MCP_AUTH_TOKEN or the backend will refuse to start (see apps/backend/src/config.ts).

