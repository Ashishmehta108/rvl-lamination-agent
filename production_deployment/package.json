{
  "name": "rvl-lamination-production",
  "version": "1.0.0",
  "description": "Production deployment setup for RVL Lamination Machine AI Agent",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "backend": "npm run start -w ../apps/backend",
    "frontend": "npm run start -w ../apps/web",
    "tunnel:front": "lt --port 3000 --subdomain lamination-ai-agent",
    "tunnel:back": "ngrok http 7000",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "electron": "^30.0.0",
    "express": "^4.19.2",
    "pm2": "^5.3.1",
    "localtunnel": "^2.0.2",
    "ngrok": "^5.0.0-beta.1"
  }
}