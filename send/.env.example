# ============================================================
#  /opt/nonwoven-agent/.env
#  Production environment for Nonwoven AI Agent pipeline
#  Copy this file, fill in real values, chmod 600 .env
# ============================================================

# ── Modbus TCP server ─────────────────────────────────────────
BIND_IP=0.0.0.0
MODBUS_PORT=502

# ── Remote backend (ngrok URL — update when tunnel changes) ──
REMOTE_BASE_URL=https://mace-ebony-capital.ngrok-free.dev
INGEST_PATH=/ingest/tags
HEALTH_PATH=/health

# ── Authentication ────────────────────────────────────────────
API_AUTH_TOKEN=your-production-token-here

# ── Machine identity ─────────────────────────────────────────
MACHINE_ID=lamination-01
MACHINE_REVISION=v1

# ── Timing ───────────────────────────────────────────────────
UPDATE_INTERVAL=0.5        # seconds between sensor reads
PUSH_INTERVAL=5.0          # seconds between push attempts

# ── HTTP tuning ───────────────────────────────────────────────
HTTP_TIMEOUT=10.0

# ── WAL / retry policy ────────────────────────────────────────
MAX_RETRIES=72             # ~6 min at 5s interval before dead-letter
RETRY_BACKOFF_CAP=60.0
SENT_KEEP_HOURS=24.0       # how long to keep successfully sent files

# ── Storage ───────────────────────────────────────────────────
BASE_DIR=/var/lib/nonwoven-agent
